# Vib ID Account Portal v1.3.0 — copy to secret storage; never commit real values.
APP_ENV=production
APP_NAME=Vib ID
APP_BASE_URL=https://id.vib.tools
APP_SECRET_KEY=GENERATE_WITH_scripts_generate_secrets.py
TOKEN_ENCRYPTION_KEY=GENERATE_WITH_scripts_generate_secrets.py
DATABASE_URL=postgresql+asyncpg://vib_id:REPLACE_WITH_STRONG_PASSWORD@vib-id-postgres:5432/vib_id
OIDC_ISSUER_URL=https://auth.vib.tools/realms/vib
OIDC_CLIENT_ID=vib-id-portal
OIDC_CLIENT_SECRET=REPLACE_FROM_KEYCLOAK
OIDC_REDIRECT_URI=https://id.vib.tools/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=https://id.vib.tools/
OIDC_SCOPES=openid profile email
OIDC_EXPECTED_AUDIENCE=vib-id-portal
OIDC_HTTP_TIMEOUT_SECONDS=5
OIDC_CLOCK_SKEW_SECONDS=30
KEYCLOAK_MANAGEMENT_CLIENT_ID=vib-id-portal-management
KEYCLOAK_MANAGEMENT_CLIENT_SECRET=REPLACE_FROM_KEYCLOAK
KEYCLOAK_MANAGEMENT_AUDIENCE=account
KEYCLOAK_ACCOUNT_URL=https://auth.vib.tools/realms/vib/account/
# Comma-separated Keycloak service-account client IDs allowed to call internal service/profile APIs.
# Recommended for connected apps: ygit-backend, ygit-dev-backend, vib-tools-backend.
KEYCLOAK_ALLOWED_INTERNAL_CLIENTS=ygit-backend,ygit-dev-backend
INTERNAL_REQUIRED_ROLE=service-connections:touch
SESSION_COOKIE_NAME=__Host-vib_id_session
SESSION_IDLE_MINUTES=30
SESSION_ABSOLUTE_HOURS=12
SESSION_MAX_CONCURRENT=10
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
SECURITY_ACTIVITY_RETENTION_DAYS=180
REVOKED_SESSION_RETENTION_DAYS=30
TRUSTED_HOSTS=id.vib.tools
CSRF_SECRET=GENERATE_WITH_scripts_generate_secrets.py
IP_PRIVACY_KEY=GENERATE_WITH_scripts_generate_secrets.py
LOG_LEVEL=INFO
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5
DATABASE_POOL_TIMEOUT=10
PROFILE_CONTACT_LIMIT=10
REQUEST_BODY_MAX_BYTES=3145728
PROFILE_AVATAR_MAX_BYTES=1048576
PROFILE_AVATAR_ALLOWED_TYPES=image/png,image/jpeg,image/webp
RATE_LIMIT_ENABLED=true
# Replace with the exact Coolify/Traefik private IP or CIDR before production traffic.
FORWARDED_ALLOW_IPS=127.0.0.1
